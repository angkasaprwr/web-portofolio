# Database (Neon PostgreSQL for production)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"

# Server
NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-frontend.vercel.app

# JWT — generate strong random secrets for production
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin Seed (used only on first seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe@Secure123
ADMIN_NAME=Admin

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
